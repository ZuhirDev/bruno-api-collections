meta {
  name: ForgotPassword
  type: http
  seq: 7
}

post {
  url: http://{{base_url}}/api/auth/forgot-password
  body: json
  auth: inherit
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "email": "admin@admin.es"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
