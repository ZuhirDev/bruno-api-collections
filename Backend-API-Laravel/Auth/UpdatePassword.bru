meta {
  name: UpdatePassword
  type: http
  seq: 5
}

post {
  url: http://{{base_url}}/api/update-password
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Accept-Language: es
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "current_password": "11111111",
    "password": "55555555",
    "password_confirmation": "55555555"
  }
  
}

settings {
  encodeUrl: true
}
